{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/regularizacion/dt5",
      "destination": "/regularizacion/dt5/index.html"
    },
    {
      "source": "/regularizacion/dt6",
      "destination": "/regularizacion/dt6/index.html"
    },
    {
      "source": "/comunidad/red-apoyo",
      "destination": "/comunidad/red-apoyo/index.html"
    },
    {
      "source": "/comunidad/fondo-solidario",
      "destination": "/comunidad/fondo-solidario/index.html"
    }
  ]
}
